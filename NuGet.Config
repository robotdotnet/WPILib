<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="Package source 1" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />
    <add key="WPILib" value="https://wpilib.jfrog.io/artifactory/api/nuget/wpilib-nuget-development-local/" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="WPILib">
      <package pattern="FRC.*" />
    </packageSource>
    <packageSource key="Package source 1">
      <package pattern="Microsoft.DotNet.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
